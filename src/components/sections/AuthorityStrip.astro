---
import Section from "../ui/Section.astro";
---

<Section>
  <div class="authority">

    <div class="item">
      <strong>FIVB Nivel 2</strong>
      <span>Certificación internacional</span>
    </div>

    <div class="item">
      <strong>Nivel 3 RFEVB</strong>
      <span>Máximo nivel en España</span>
    </div>

    <div class="item">
      <strong>Nivel 2 FEVA</strong>
      <span>Máximo nivel en Argentina</span>
    </div>

    <div class="item">
      <strong>+30 años</strong>
      <span>Dentro del voleibol</span>
    </div>

  </div>
</Section>

<style>

.authority {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
  text-align: center;
}

.item strong {
  display: block;
  font-size: 1.2rem;
  margin-bottom: 0.3rem;
}

.item span {
  font-size: 0.9rem;
  color: #666;
}

@media (max-width: 800px) {
  .authority {
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
}

</style>