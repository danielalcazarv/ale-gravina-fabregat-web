---
import Container from "../layout/Container.astro";
---

<section class="hero">
  <Container>
    <div class="hero-grid">

      <div class="hero-text">

        <h1>
          Entrena mejor.<br />
          Desde dentro.
        </h1>

        <p class="subtitle">
          Diseño programas de formación, clínicas y asesorías técnicas que elevan el nivel del cuerpo técnico y sostienen el rendimiento durante la temporada.
        </p>

        <p class="bio">
          Profesor de Educación Física con un perfil pedagógico, metodología de enseñanza integral, coaching y programación neurolingüística.
        </p>
        
        <div class="hero-actions">
          <a class="btn-primary" href="/contacto">
            Hablemos de tu proyecto

            <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm4.5 5.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z"/>
            </svg>
          </a>
        </div>

      </div>

      <div class="hero-image">
        <img src=/hero.png alt="Ale Gravina Fabregat entrenador de vóley" />
      </div>

    </div>
  </Container>
</section>

<style>

.hero {
  padding: 80px 0 40px 0;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 3rem;
  align-items: center;
}

.hero-text h1 {
  font-size: 3rem;
  line-height: 1.2;
  margin-bottom: 1.2rem;
}

.subtitle {
  font-size: 1.25rem;
  margin-bottom: 1.5rem;
  color: var(--color-muted);
}

.bio {
  font-size: 0.95rem;
  color: var(--color-subtle);
  max-width: 550px;
  margin-bottom: 2rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
}

.btn-primary {
  display:inline-flex;
  align-items:center;
  gap:0.5rem;
  background: var(--color-accent);
  color: var(--color-on-accent);
  padding: 0.8rem 1.6rem;
  text-decoration: none;
  font-weight: 500;
  border-radius: 4px;
}

.btn-primary:hover {
  background: var(--color-hover);
  color: var(--color-accent);
  transform: translateY(-1px);
}

.icon{
  width: 1.125rem;
  height: 1.125rem;
  fill: currentColor;
  flex-shrink: 0;
}

.hero-image img {
  width: 100%;
  height: auto;
  border-radius: 10px;
}

@media (max-width: 900px) {
  .hero-grid {
    grid-template-columns: 1fr;
  }

  .hero-text h1 {
    font-size: 2.4rem;
  }
}

@media (max-width: 768px) {
  .hero {
    padding: 50px 0 28px 0;
  }

  .hero-text h1 {
    font-size: 2rem;
  }

  .subtitle {
    font-size: 1.1rem;
  }

  .hero-grid {
    gap: 2rem;
  }
}

@media (max-width: 480px) {
  .hero {
    padding: 36px 0 24px 0;
  }

  .hero-text h1 {
    font-size: 1.75rem;
  }

  .subtitle {
    font-size: 1rem;
    margin-bottom: 1.2rem;
  }

  .bio {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .hero-grid {
    gap: 1.5rem;
  }
}

</style>