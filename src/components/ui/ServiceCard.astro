---
const { title, description, result, cta } = Astro.props;
---

<article class="service-card">

    <h3>{title}</h3>

    <p class="service-description">
        {description}
    </p>

    <p class="service-result">
        <strong>¿Qué se llevan?</strong><br/>
        {result}
    </p>

    <a class="service-button" 
        href="/contacto">
        {cta}
        <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm4.5 5.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z"/>
        </svg>
    </a>

</article>


<style>

.service-card{
  padding:1.8rem;
  border:1px solid #e5e5e5;
  border-radius:10px;
}

.service-card h3{
  margin-bottom:0.8rem;
}

.service-description{
  margin-bottom:1rem;
  line-height:1.6;
}

.service-result{
  font-size:0.9rem;
  margin-bottom:1.2rem;
  color:#555;
}

.service-button {
    display:inline-flex;
    align-items:center;
    gap:0.5rem;
    margin-top: 0.5rem;
    background: #000;
    color: #fff;
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.2s ease;
}

.service-button:hover {
  background: #eaeaea;
  color: #000;
  transform: translateY(-1px);
}

.icon{
  width:18px;
  height:18px;
  fill:currentColor;
}

</style>