---
const { title, description, result, cta } = Astro.props;
---

<article class="service-card">

    <h3>{title}</h3>

    <p class="service-description">
        {description}
    </p>

    <p class="service-result">
        <strong>¿Qué se llevan?</strong><br/>
        {result}
    </p>

    <a class="service-button" 
        href="/contacto">
        {cta}
    </a>

</article>


<style>

.service-card{
  padding:1.8rem;
  border:1px solid #e5e5e5;
  border-radius:10px;
}

.service-card h3{
  margin-bottom:0.8rem;
}

.service-description{
  margin-bottom:1rem;
  line-height:1.6;
}

.service-result{
  font-size:0.9rem;
  margin-bottom:1.2rem;
  color:#555;
}

.service-button {
  display: inline-block;
  margin-top: 0.5rem;
  background: #000;
  color: #fff;
  padding: 0.55rem 1.1rem;
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 500;
  text-decoration: none;
  transition: transform 0.15s ease, background 0.2s ease;
}

.service-button:hover {
  background: #222;
  transform: translateY(-1px);
}

</style>