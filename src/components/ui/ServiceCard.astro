---
const { title, subtitle, description, result, cta, asunto } = Astro.props;
const contactoLink = `/contacto?asunto=${asunto}`
---

<article class="service-card">

    <h2>{title}</h2>
    <h3>{subtitle}</h3>

    <div class="service-description">
      <p>{description}</p>
      <button class="read-more">+</button>
    </div>

    <p class="service-result">
        <strong>¿Qué se llevan?</strong><br/>
        {result}
    </p>

    <a class="service-button" 
        href={contactoLink}>
        {cta}
        <svg class="icon" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 2a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1zM0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm4.5 5.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z"/>
        </svg>
    </a>

</article>


<style>

.service-card{
  padding:1.8rem;
  border:1px solid var(--color-border);
  border-radius:10px;
  background: var(--color-bg);

  display:flex;
  flex-direction:column;

  transition:
    transform .2s ease,
    box-shadow .2s ease,
    border-color .2s ease;
}

.service-card:hover{
  transform:translateY(-4px);

  border-color: var(--color-border-hover);

  box-shadow:
    0 8px 24px rgba(0,0,0,0.08);
}

.service-card h2{
  margin-bottom:1rem;
  font-size:1.2rem;
}

.service-card h3{
  margin-bottom:0.6rem;
  font-size:0.9rem;
}

.service-description p{
  line-height:1.6;
  color: var(--color-muted);

  display:-webkit-box;
  -webkit-line-clamp:2;
  -webkit-box-orient:vertical;
  overflow:hidden;

  transition:all .25s ease;
}

.service-description.expanded p{
  -webkit-line-clamp:unset;
}

.read-more{
  display: block;
  margin-left:auto;
  margin-top:0.3rem;
  background:none;
  border:none;
  cursor:pointer;
  font-size:1rem;
  font-weight:600;
}

.service-result{
  font-size:0.9rem;
  margin-bottom:1.2rem;
  color: var(--color-muted);
}

.service-button {
    display:inline-flex;
    align-self:flex-end;
    align-items:center;
    gap:0.5rem;
    margin-top: 0.5rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.2s ease;
}

.service-button:hover {
  background: var(--color-hover);
  color: var(--color-accent);
  transform: translateY(-1px);
}

.icon{
  width: 1.125rem;
  height: 1.125rem;
  fill: currentColor;
  flex-shrink: 0;
}

@media (max-width: 480px) {
  .service-card {
    padding: 1.2rem;
  }

  .service-card h2 {
    font-size: 1.1rem;
  }

  .service-button {
    align-self: stretch;
    justify-content: center;
  }
}

</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".read-more").forEach(btn => {
      btn.addEventListener("click", () => {
        const container = btn.closest(".service-description")
        container.classList.toggle("expanded")
        btn.textContent = container.classList.contains("expanded") ? "−" : "+"
      })
    })
  })
</script>