---
import Container from "../layout/Container.astro";

const { title, subtitle, id } = Astro.props;
---

<section id={id} class="section">
  <Container>

    {title && (
      <header class="section-header">
        <h2>{title}</h2>

        {subtitle && (
          <p class="section-subtitle">{subtitle}</p>
        )}
      </header>
    )}

    <div class="section-content">
      <slot />
    </div>

  </Container>
</section>

<style>

.section {
  padding: 80px 0;
}

.section-header {
  margin-bottom: 3rem;
  max-width: 700px;
}

.section-header h2 {
  font-size: 2rem;
  margin-bottom: 0.8rem;
}

.section-subtitle {
  color: #666;
  font-size: 1.05rem;
}

.section-content {
  width: 100%;
}

</style>